# Django
DJANGO_SETTINGS_MODULE=realestate_platform.settings.local
SECRET_KEY=change-me
DEBUG=1
ALLOWED_HOSTS=127.0.0.1,localhost

# Database
DATABASE_URL=postgres://postgres:postgres@db:5432/realestate

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# CORS
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=RealEstate <noreply@example.com>

# Stripe (Card)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# MOMO
MOMO_API_KEY=your-momo-api-key
MOMO_API_SECRET=your-momo-secret
MOMO_WEBHOOK_SECRET=your-momo-webhook-secret

# SMS Provider
SMS_API_KEY=your-sms-api-key
SMS_SENDER=RealEstate

# SSO
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=your-google-client-id
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=your-google-client-secret
SOCIAL_AUTH_APPLE_CLIENT_ID=your-apple-client-id
SOCIAL_AUTH_APPLE_TEAM_ID=team-id
SOCIAL_AUTH_APPLE_KEY_ID=key-id
SOCIAL_AUTH_APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
