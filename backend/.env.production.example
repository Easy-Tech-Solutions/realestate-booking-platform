DJANGO_SECRET_KEY=replace-with-64-char-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=api.yourdomain.com

FRONTEND_ORIGIN=https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

AUTH_REQUIRE_EMAIL_VERIFICATION=true

# Database
DB_ENGINE=postgres
POSTGRES_DB=realestate_prod
POSTGRES_USER=realestate_user
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=120

# Redis / channels / celery
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_ALWAYS_EAGER=false

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-smtp-user@yourdomain.com
EMAIL_HOST_PASSWORD=replace-with-smtp-password
DEFAULT_FROM_EMAIL=Real Estate <noreply@yourdomain.com>

# Site metadata
LOCAL_DOMAIN=api.yourdomain.com
SITE_NAME=Real Estate Booking Platform

# Security
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000

# MTN MoMo
MTN_MOMO_API_KEY=replace-with-mtn-api-key
MTN_MOMO_USER_ID=replace-with-mtn-user-id
MTN_MOMO_API_SECRET=replace-with-mtn-api-secret
MTN_BUSINESS_NUMBER=replace-with-mtn-disbursement-key

# Optional integrations
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_KEY=
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_API_SECRET=
