DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_ORIGIN=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Auth
AUTH_REQUIRE_EMAIL_VERIFICATION=true

# Database
DB_ENGINE=sqlite
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# Domain
LOCAL_DOMAIN=localhost:8000
SITE_NAME=Real Estate Booking Platform

# Flutterwave (optional)
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_KEY=

# MTN Mobile Money
MTN_MOMO_API_KEY=
MTN_MOMO_USER_ID=
MTN_MOMO_API_SECRET=
MTN_BUSINESS_NUMBER=

# Orange Money (optional)
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_API_SECRET=

# Redis (optional — leave blank to use in-memory channel layer and eager Celery)
REDIS_URL=

# Celery (set to false in production)
CELERY_ALWAYS_EAGER=true

# Security
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
