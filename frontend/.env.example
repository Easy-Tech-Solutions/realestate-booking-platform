# Frontend environment variables (Vite)
# IMPORTANT: These are baked into the production bundle at BUILD TIME.
# Set them in your CI/CD environment before running `vite build`.

# Backend API base URL — REQUIRED in production.
# Without this, the build defaults to http://localhost:8000 and all API calls will fail.
VITE_API_URL=https://your-backend-domain.com

# WebSocket URL — optional; derived from window.location if not set.
VITE_WS_URL=

# Google OAuth2 client ID (public — safe to expose in frontend bundle)
VITE_GOOGLE_OAUTH_CLIENT_ID=

# Stripe publishable key (public — safe to expose in frontend bundle)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
